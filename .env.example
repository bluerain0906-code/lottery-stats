# LINE Login Channel（取自 LINE Developers Console）
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret

# OAuth Callback（本機測試用 http://localhost:3000/auth/line/callback，
# 正式用 https://你網址.zeabur.app/auth/line/callback）
LINE_CALLBACK_URL=http://localhost:3000/auth/line/callback

# 管理員 LINE User ID（多個用逗號分隔，無空格）
ADMIN_LINE_USER_IDS=U0123abcdef

# JWT 簽章密鑰（隨意長字串，至少 32 字元）
# 產生：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# 正式部署時設為 production
NODE_ENV=development
PORT=3000
